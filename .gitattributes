# Set default behavior to automatically normalize line endings
* text=auto

# Set specific file types to have specific line endings
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.apk binary
*.ipa binary
*.app binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.rar binary

# Font files
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# Document files
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
