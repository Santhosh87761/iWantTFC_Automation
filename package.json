{
  "name": "igs-wdio-framework",
  "version": "1.0.0",
  "description": "IGS WebDriverIO Automation Framework for cross-platform testing including web, mobile (Android/iOS), TV, and API testing capabilities",
  "main": "index.js",
  "author": "IGS Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist/ allure-results/ allure-report/ timeline-reports/",
    "lint": "eslint src/ test/ config/ --ext .ts",
    "lint:fix": "eslint src/ test/ config/ --ext .ts --fix",
    "web": "npm run clean && node scripts/run-wdio.js web",
    "web:quick": "node scripts/run-wdio.js web",
    "web:cucumber": "npm run clean && wdio run config/wdio.web.cucumber.config.ts",
    "remote": "npm run multiremote",
    "multiremote": "npm run clean && node scripts/run-wdio.js multiremote",
    "test:multiremote": "npm run multiremote",
    "android": "node scripts/run-wdio.js android",
    "mobile": "node scripts/run-wdio.js android",
    "android:check": "node scripts/check-android-setup.js",
    "android:full": "npm run android:check && npm run android",
    "ios": "npm run clean && node scripts/run-wdio.js ios",
    "multi": "npm run clean && node scripts/run-parallel-platforms.js web android",
    "api": "npm run clean && wdio run config/wdio.api.config.ts",
    "allure:generate": "node scripts/generate-allure-report.js allure-report",
    "allure:open": "node scripts/open-allure-report.js allure-report",
    "allure:serve": "allure serve allure-results",
    "workspace:cleanup": "powershell -File cleanup-workspace.ps1",
    "mcp:serve": "node mcp-server.js",
    "start": "npm run web"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igs/igs-wdio-framework.git"
  },
  "keywords": [
    "WebdriverIO",
    "automation",
    "testing",
    "appium",
    "mobile",
    "web",
    "tv",
    "framework",
    "typescript"
  ],
  "devDependencies": {
    "@cucumber/cucumber": "^12.6.0",
    "@faker-js/faker": "^9.9.0",
    "@types/chai": "^5.2.2",
    "@types/node": "^24.1.0",
    "@types/tesseract.js": "^0.0.2",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@wdio/allure-reporter": "^9.18.0",
    "@wdio/appium-service": "^9.18.4",
    "@wdio/cli": "^9.18.4",
    "@wdio/cucumber-framework": "^9.23.3",
    "@wdio/local-runner": "^9.24.0",
    "@wdio/mocha-framework": "^9.24.0",
    "@wdio/spec-reporter": "^9.24.0",
    "allure-commandline": "^2.34.1",
    "appium": "^2.19.0",
    "appium-uiautomator2-driver": "^4.2.7",
    "axios": "^1.11.0",
    "chai": "^5.2.1",
    "chromedriver": "^138.0.4",
    "dotenv": "^17.2.1",
    "eslint": "^9.32.0",
    "lodash": "^4.17.21",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "wdio-edgedriver-service": "^3.0.3",
    "wdio-timeline-reporter": "^5.1.4",
    "webdriverio": "^9.24.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "express": "^4.18.2",
    "tesseract.js": "^7.0.0"
  }
}
