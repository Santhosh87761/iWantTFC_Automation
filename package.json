{
  "name": "igs-wdio-framework",
  "version": "1.0.0",
  "description": "IGS WebDriverIO Automation Framework for cross-platform testing including web, mobile (Android/iOS), and API testing capabilities",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist/ && rimraf allure-results/ && rimraf allure-report/ && rimraf timeline-reports/",
    "test:web": "npm run clean && wdio config/wdio.web.config.ts",
    "test:web:quick": "wdio config/wdio.web.config.ts",
    "test:android": "wdio config/wdio.android.config.ts",
    "test:android:check": "node scripts/check-android-setup.js",
    "test:android:full": "npm run test:android:check && npm run test:android",
    "test:ios": "npm run clean && wdio config/wdio.ios.config.ts",
    "test:multiremote": "npm run clean && wdio config/wdio.multiremote.config.ts",
    "test:api": "npm run clean && wdio config/wdio.api.config.ts",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "lint": "eslint src/ test/ config/ --ext .ts",
    "lint:fix": "eslint src/ test/ config/ --ext .ts --fix",
    "pretest": "npm run lint",
    "start": "npm run test:web",
    "workspace:cleanup": "powershell -File cleanup-workspace.ps1",
    "mcp:serve": "node mcp-server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igs/igs-wdio-framework.git"
  },
  "keywords": [
    "WebdriverIO",
    "WebDriver",
    "automation",
    "testing",
    "appium",
    "mobile",
    "web",
    "framework",
    "IGS",
    "typescript"
  ],
  "engines": {
    "node": "^16.13.0 || >=20.0.0"
  },
  "author": "IGS Team",
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@types/chai": "^5.2.2",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@wdio/allure-reporter": "^9.18.0",
    "@wdio/appium-service": "^9.18.4",
    "@wdio/cli": "^9.18.4",
    "@wdio/local-runner": "^9.18.4",
    "@wdio/mocha-framework": "^9.18.0",
    "@wdio/spec-reporter": "^9.18.0",
    "allure-commandline": "^2.34.1",
    "appium": "^2.19.0",
    "appium-uiautomator2-driver": "^4.2.7",
    "axios": "^1.11.0",
    "chai": "^5.2.1",
    "chromedriver": "^138.0.4",
    "dotenv": "^17.2.1",
    "eslint": "^9.32.0",
    "lodash": "^4.17.21",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "wdio-timeline-reporter": "^5.1.4",
    "webdriverio": "^9.18.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "express": "^4.18.2"
  }
}
