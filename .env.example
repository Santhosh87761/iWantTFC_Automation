# Environment Configuration

# Base URLs for different environments
BASE_URL=https://example.com
STAGING_URL=https://staging.example.com
PROD_URL=https://prod.example.com

# Mobile App Paths
ANDROID_APP_PATH=./apps/android/app-debug.apk
IOS_APP_PATH=./apps/ios/IGSApp.app

# Mobile Device Configuration
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_PLATFORM_VERSION=11
IOS_DEVICE_NAME=iPhone 14
IOS_PLATFORM_VERSION=16.0

# App Configuration
ANDROID_APP_PACKAGE=com.igs.testapp
ANDROID_APP_ACTIVITY=.MainActivity
IOS_BUNDLE_ID=com.igs.testapp

# Test Configuration
DEBUG_MODE=false
HEADLESS_MODE=false
BROWSER_WIDTH=1920
BROWSER_HEIGHT=1080
TIMEOUT=30000

# Reporting
GENERATE_ALLURE_REPORT=false
SCREENSHOT_ON_FAILURE=true
VIDEO_RECORDING=false

# API Testing
API_BASE_URL=https://api.example.com
API_TIMEOUT=30000
API_RETRY_COUNT=3

# Database (if needed)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=testdb
DB_USER=testuser
DB_PASSWORD=testpass

# Cloud Testing (BrowserStack/Sauce Labs)
BS_USERNAME=
BS_ACCESS_KEY=
SAUCE_USERNAME=
SAUCE_ACCESS_KEY=

# Slack/Teams Notifications
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
