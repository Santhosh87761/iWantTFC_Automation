{
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/logs/**": true,
        "**/screenshots/**": true,
        "**/src/helpers/**": true,
        "**/src/utils/**": true,
        "**/src/config/**": true,
        "**/*_fixed.ts": true,
        "**/*_corrected.ts": true,
        "**/*.old": true,
        "**/*.bak": true
    },
    "files.exclude": {
        "**/src/helpers": true,
        "**/src/utils": true,
        "**/src/config": true,
        "**/*_fixed.ts": true,
        "**/*_corrected.ts": true,
        "**/*.old": true,
        "**/*.bak": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/logs": true,
        "**/screenshots": true,
        "**/src/helpers": true,
        "**/src/utils": true,
        "**/src/config": true,
        "**/*_fixed.ts": true,
        "**/*_corrected.ts": true,
        "**/*.old": true,
        "**/*.bak": true
    },
    "typescript.preferences.includePackageJsonAutoImports": "off",
    "typescript.suggest.autoImports": false,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "source.organizeImports": "explicit"
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml"
    }
}
